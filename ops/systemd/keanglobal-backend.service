[Unit]
Description=KeanGlobal FastAPI backend
After=network.target

[Service]
User=deploy
Group=deploy
WorkingDirectory=/opt/keanglobal/backend
EnvironmentFile=/opt/keanglobal/backend/.env
ExecStart=/opt/keanglobal/backend/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
